          { "matcher": { "id": "byName", "options": "Output" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        { "expr": "sum(librefang_tokens_input_total)", "legendFormat": "Input", "refId": "A", "instant": true },
        { "expr": "sum(librefang_tokens_output_total)", "legendFormat": "Output", "refId": "B", "instant": true }
      ]
