# Copy this file to secrets.env (which is gitignored), fill in real values,
# then apply: kubectl apply -k deploy/k8s
#
# These values are mounted into the librefang-secrets Kubernetes Secret and
# injected as environment variables into the librefang pod. Never commit the
# populated secrets.env — it is listed in .gitignore.

# --- LLM providers ---
ANTHROPIC_API_KEY=        # Anthropic Claude
GEMINI_API_KEY=           # Google Gemini
OPENAI_API_KEY=           # OpenAI
GROQ_API_KEY=             # Groq
DASHSCOPE_API_KEY=        # Alibaba DashScope / Qwen
MINIMAX_API_KEY=          # MiniMax
DEEPSEEK_API_KEY=         # DeepSeek
OPENROUTER_API_KEY=       # OpenRouter
TOGETHER_API_KEY=         # Together AI
MISTRAL_API_KEY=          # Mistral
FIREWORKS_API_KEY=        # Fireworks AI

# --- Messaging / channel integrations ---
TELEGRAM_BOT_TOKEN=       # Telegram bot token
DISCORD_BOT_TOKEN=        # Discord bot token
SLACK_BOT_TOKEN=          # Slack bot OAuth token (xoxb-)
SLACK_APP_TOKEN=          # Slack app-level token (xapp-)
WHATSAPP_TOKEN=           # WhatsApp Cloud API token
MATRIX_ACCESS_TOKEN=      # Matrix/Element access token
EMAIL_PASSWORD=           # SMTP/IMAP account password

# --- LibreFang service auth ---
LIBREFANG_API_KEY=        # API key for authenticated LibreFang API requests
LIBREFANG_DASHBOARD_PASS= # Password for the built-in web dashboard
